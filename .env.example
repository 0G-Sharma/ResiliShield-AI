# ====================================================
# RESILISHIELD AI ENVIRONMENT VARIABLES
# ====================================================

# Frontend Variables
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend FastAPI Variables
ENV=development
PORT=8000

# Google Cloud Platform (GCP) Configuration
# (Required if configuring live production Vertex AI & BigQuery access)
GCP_PROJECT_ID=resilishield-ai-prod
GCP_LOCATION=us-central1
GCP_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Vertex AI Settings
VERTEX_AI_GEMINI_MODEL=gemini-1.5-flash
VERTEX_AI_API_KEY=your_vertex_ai_secret_key_here

# SQLite Database
DATABASE_URL=sqlite:///./resilishield.db
